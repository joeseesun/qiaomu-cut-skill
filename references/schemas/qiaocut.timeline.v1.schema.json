{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/joeseesun/qiaomu-cut/schemas/qiaocut.timeline.v1.schema.json",
  "title": "QiaoCut Render Timeline v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema", "output", "shots"],
  "properties": {
    "schema": { "const": "qiaocut.timeline.v1" },
    "title": { "type": "string" },
    "output": {
      "type": "object",
      "additionalProperties": true,
      "required": ["width", "height", "fps", "duration", "file"],
      "properties": {
        "width": { "type": "integer", "minimum": 320, "multipleOf": 2 },
        "height": { "type": "integer", "minimum": 240, "multipleOf": 2 },
        "fps": { "type": "number", "exclusiveMinimum": 0 },
        "duration": { "type": "number", "exclusiveMinimum": 0 },
        "file": { "$ref": "#/$defs/projectPath" },
        "loudnessLufs": { "type": "number", "minimum": -70, "maximum": -5 },
        "truePeakDb": { "type": "number", "minimum": -9, "maximum": -0.1 },
        "crf": { "type": "number", "minimum": 0, "maximum": 51 },
        "preset": { "type": "string" },
        "audioBitrate": { "type": "string" }
      }
    },
    "captionSource": { "$ref": "#/$defs/projectPath" },
    "captions": { "$ref": "#/$defs/projectPath" },
    "font": { "type": "string" },
    "fontsDir": { "$ref": "#/$defs/projectPath" },
    "narration": {
      "oneOf": [
        { "$ref": "#/$defs/projectPath" },
        { "$ref": "#/$defs/narration" }
      ]
    },
    "music": {
      "oneOf": [
        { "const": false },
        { "$ref": "#/$defs/projectPath" },
        {
          "type": "object",
          "additionalProperties": true,
          "required": ["mode"],
          "properties": {
            "mode": { "enum": ["procedural", "file", "none"] },
            "path": { "$ref": "#/$defs/projectPath" },
            "bpm": { "type": "number", "minimum": 40, "maximum": 180 },
            "seed": { "type": "integer" },
            "energy": { "type": "number", "minimum": 0, "maximum": 1 },
            "rootMidi": { "type": "integer", "minimum": 24, "maximum": 72 }
          }
        }
      ]
    },
    "musicOptions": { "type": "object", "additionalProperties": true },
    "audio": { "type": "object", "additionalProperties": true },
    "look": { "type": "object", "additionalProperties": true },
    "metadata": { "type": "object", "additionalProperties": { "type": ["string", "number", "boolean"] } },
    "reports": { "type": "object", "additionalProperties": true },
    "shots": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/shot" }
    }
  },
  "$defs": {
    "projectPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:[\\\\/])(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+$"
    },
    "shot": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "kind", "path", "duration"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["image", "video"] },
        "path": { "$ref": "#/$defs/projectPath" },
        "in": { "type": "number", "minimum": 0 },
        "duration": { "type": "number", "exclusiveMinimum": 0 },
        "fit": { "enum": ["cover", "contain", "containBlur"] },
        "motion": { "enum": ["none", "pushIn", "pullBack", "panUp", "panDown", "panLeft", "panRight"] },
        "sourceAudio": { "type": "boolean" },
        "sourceGainDb": { "type": "number", "minimum": -60, "maximum": 24 },
        "look": { "type": "object", "additionalProperties": true }
      }
    },
    "narration": {
      "type": "object",
      "additionalProperties": true,
      "required": ["engine"],
      "properties": {
        "engine": { "enum": ["macos-say", "file", "none"] },
        "path": { "$ref": "#/$defs/projectPath" },
        "start": { "type": "number", "minimum": 0 },
        "trim": { "type": "number", "minimum": 0 },
        "duration": { "type": "number", "exclusiveMinimum": 0 },
        "gain": { "type": "number", "minimum": 0, "maximum": 4 },
        "provider": { "type": "string" },
        "assetId": { "type": "string" },
        "speakerId": { "type": "string" },
        "speakerName": { "type": "string" },
        "narrationTextSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "voice": { "type": "string" },
        "rate": { "type": "number", "exclusiveMinimum": 0 },
        "cues": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["start", "text"],
            "properties": {
              "id": { "type": "string" },
              "start": { "type": "number", "minimum": 0 },
              "maxDuration": { "type": "number", "exclusiveMinimum": 0 },
              "text": { "type": "string", "minLength": 1 },
              "voice": { "type": "string" },
              "rate": { "type": "number", "exclusiveMinimum": 0 },
              "gain": { "type": "number", "minimum": 0, "maximum": 4 }
            }
          }
        }
      },
      "oneOf": [
        {
          "properties": { "engine": { "const": "macos-say" } },
          "required": ["cues"]
        },
        {
          "properties": { "engine": { "const": "file" } },
          "required": ["path"]
        },
        {
          "properties": { "engine": { "const": "none" } }
        }
      ],
      "allOf": [
        {
          "if": {
            "properties": { "provider": { "const": "listenhub" } },
            "required": ["provider"]
          },
          "then": {
            "required": ["assetId", "speakerId", "speakerName", "narrationTextSha256"]
          }
        }
      ]
    }
  }
}
