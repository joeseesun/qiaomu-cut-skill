{
  "name": "qiaomu-cut-skill",
  "version": "0.3.0",
  "private": true,
  "description": "Qiaomu agent-native video director skill with preview, standard, and final render profiles",
  "type": "commonjs",
  "bin": {
    "qcut": "scripts/qcut.js"
  },
  "scripts": {
    "doctor": "node scripts/qcut.js doctor",
    "clipseek": "node scripts/qcut.js clipseek",
    "plan": "node scripts/qcut.js plan",
    "render": "node scripts/qcut.js render",
    "render:preview": "node scripts/qcut.js render --profile preview",
    "render:standard": "node scripts/qcut.js render --profile standard",
    "render:final": "node scripts/qcut.js render --profile final",
    "security-smoke": "node scripts/security_smoke.js",
    "release-check": "node scripts/release_check.js",
    "workflow": "node scripts/qcut.js workflow list",
    "validate": "python3 scripts/validate_skill.py .",
    "trigger-eval": "python3 scripts/trigger_eval.py . --cases evals/trigger_cases.json --output reports/trigger-eval.json"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
